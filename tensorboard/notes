#################################################
# Container validation checklist like in the CI #
#################################################

# 1) Start from a fresh clone in the container
git -c core.autocrlf=false clone https://github.com/psamanoelton/tensorboard.git --branch protobuf /workspace/tensorboard
cd /workspace/tensorboard

# 2) Install Bazel-side Python deps
python -m pip install -U pip
pip install \
  -r ./tensorboard/pip_package/requirements.txt \
  -r ./tensorboard/pip_package/requirements_dev.txt

# 3) TF lane only: install TensorFlow and remove any installed TensorBoard wheel
pip install tf-nightly
pip uninstall -y tensorboard tb-nightly || true

# 4) Ensure Python headers are where Bazel's system_python repo expects them
export pythonLocation=/opt/tb-venv
py_abi=python3.10
mkdir -p "${pythonLocation}/include"
if [ ! -f "${pythonLocation}/include/${py_abi}/Python.h" ]; then
  rm -rf "${pythonLocation}/include/${py_abi}"
  ln -s "/usr/include/${py_abi}" "${pythonLocation}/include/${py_abi}"
fi
test -f "${pythonLocation}/include/${py_abi}/Python.h"

# 5) Fast failure checks for the current CI blocker surface
bazel shutdown
bazel clean --expunge
bazel fetch //tensorboard/...
bazel build //tensorboard/... --nobuild

# 6) Full TF validation path
( set -o pipefail; bazel build //tensorboard/... |& grep -v 'external/com_google_protobuf/python: warning: directory' |& grep -v 'INFO: From ProtoCompile ' )
bazel test //tensorboard/... --test_output=errors --keep_going --cache_test_results=no
bazel build //tensorboard/pip_package:test_pip_package
./bazel-bin/tensorboard/pip_package/test_pip_package --tf-version tf-nightly
bazel test //tensorboard/compat/tensorflow_stub:gfile_s3_test
bazel test //tensorboard/summary/writer:event_file_writer_s3_test
bazel test //tensorboard/compat/tensorflow_stub:gfile_fsspec_test
bazel test //tensorboard/summary/writer:event_file_writer_fsspec_test

# 7) Non-TF validation path
python -m pip install -U pip
pip install \
  -r ./tensorboard/pip_package/requirements.txt \
  -r ./tensorboard/pip_package/requirements_dev.txt
bazel shutdown
bazel clean --expunge
bazel fetch //tensorboard/...
( set -o pipefail; bazel build //tensorboard/... |& grep -v 'external/com_google_protobuf/python: warning: directory' |& grep -v 'INFO: From ProtoCompile ' )
bazel test //tensorboard/... --test_tag_filters="support_notf" --test_output=errors --keep_going --cache_test_results=no
bazel build //tensorboard/pip_package:test_pip_package
./bazel-bin/tensorboard/pip_package/test_pip_package --tf-version notf
bazel test //tensorboard/compat/tensorflow_stub:gfile_fsspec_test
bazel test //tensorboard/summary/writer:event_file_writer_fsspec_test





